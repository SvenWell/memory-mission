# memory-mission deployment env. Copy to deploy/.env.local and fill in.
# `.env.local` is gitignored — never commit real values.
#
# Sourced by deploy/cron/mm-refresh.sh; values become env for every script
# under deploy/scripts/* via deploy/scripts/_config.py.

# --- Identity (required) ---------------------------------------------------

# Your employee/user identity within memory-mission.
# Used as the staging directory name and as the MemPalace per-employee key.
MM_USER_ID=

# Firm identity — defaults to MM_USER_ID for solo deployments.
MM_FIRM_ID=

# Firm root data dir. memory-mission stores identity.db, personal/, wiki/,
# .observability/, etc. underneath.
MM_FIRM_ROOT=/root/memory-mission-data

# --- Composio (required for backfills) ------------------------------------

# API key for the Composio account that holds your toolkit connections.
COMPOSIO_API_KEY=

# --- Source accounts (set what applies) -----------------------------------

# Format: "label:composio-connection-user-id,label:composio-connection-user-id"
# Example: "primary:my-google,work:my-work-google"
# The label becomes the per-source log name (cal-primary.log etc).
MM_GMAIL_ACCOUNTS=
MM_CALENDAR_ACCOUNTS=

# Single Composio user_id for Granola. Leave unset to skip granola ingestion.
MM_GRANOLA_USER_ID=

# --- CRM targets (push_to_crm.py --target=<name>) -------------------------
# Each target is independent. Leave a target's vars unset to skip that
# CRM in the daily cron.

# HubSpot — Composio user_id for the connection. The script matches by
# email (contacts) / domain (companies); no extra setup required.
MM_HUBSPOT_USER_ID=

# Notion — Composio user_id + the database IDs that --provision creates
# under the parent page. Run once to set them up:
#   python deploy/scripts/push_to_crm.py --target=notion --provision
MM_NOTION_USER_ID=
MM_NOTION_PARENT_PAGE_ID=
MM_NOTION_CONTACTS_DB_ID=
MM_NOTION_COMPANIES_DB_ID=

# --- Visualization (optional) ---------------------------------------------

# Comma-separated entity ids to render as ego networks in visualize_kg.py.
# Empty = hub view + index only.
MM_VIZ_CENTERS=

# Override visualize_kg output dir. Defaults to $MM_FIRM_ROOT/kg_viz.
MM_VIZ_OUT_DIR=
